!! Colorscheme

! special
!*.foreground: #ffff 
*.foreground:   #ffffff
!*.background: [80]#0A0E14
!*.background: #0c0c0d
*.background: #000000
*.cursorColor: #afbfbf

! black
*.color0: #01060E
*.color8: #686868

! red
*.color1: #EA6C73
*.color9: #F07178

! green
*.color2: #91B362
*.color10: #C2D94C

! yellow
*.color3: #F9AF4F
*.color11: #FFB454

! blue
*.color4: #53BDFA
*.color12: #59C2FF

! magenta
*.color5: #FAE994
*.color13: #FFEE99

! cyan
*.color6: #90E1C6
*.color14: #95E6CB

! white
*.color7: #C7C7C7
*.color15: #ffffff

!*.depth: 32

!*.geometry: 78x40+20+20
*.scrollBar: false

*.font: xft:Comic Mono:size=10:
!*.font: xft:Comic Mono:size=10:
!*.font: xft:Comic Mono:size=10:

! Restore Ctrl+Shift+(c|v)
*.keysym.Shift-Control-V: eval:paste_clipboard
*.keysym.Shift-Control-C: eval:selection_to_clipboard
*.iso14755: false
*.iso14755_52: false

! do not scroll with output
*.scrollTtyOutput: false

! scroll in relation to buffer (with mouse scroll or Shift+Page Up)
*.scrollWithBuffer: true

! scroll back to the bottom on keypress
*.scrollTtyKeypress: true

*.internalBorder: 4 

*.perl-ext-common: default,matcher,-confirm-paste
*.url-launcher: firefox
*.matcher.button: 1
